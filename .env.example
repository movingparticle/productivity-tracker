# =============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO  (copia este archivo a .env)
# =============================================================
#  1. Copia este archivo y renómbralo a ".env"
#  2. Rellena tus llaves reales en ".env" (NUNCA en este .example)
#  3. El archivo ".env" está en .gitignore: nunca se sube a git.
#
#  En PRODUCCIÓN (Vercel) estas mismas variables se configuran en:
#  Vercel -> tu proyecto -> Settings -> Environment Variables
# =============================================================

# ---- AGENTE DE IA (DeepSeek, compatible con el formato OpenAI) ----
# Consigue tu llave en: https://platform.deepseek.com/api_keys
LLM1_BASE_URL=https://api.deepseek.com
LLM1_KEY=pon-aqui-tu-llave-de-deepseek
LLM1_MODEL=deepseek-chat

# (Opcional) Proveedor de respaldo si el primario falla.
# Puede ser otro DeepSeek, OpenAI, Groq, OpenRouter, etc.
# LLM2_BASE_URL=
# LLM2_KEY=
# LLM2_MODEL=

# ---- CUOTA GRATIS DEL AGENTE (peticiones por usuario al día) ----
FREE_DAILY_LIMIT=5

# ---- CÓDIGOS DE ACCESO (prueba Pro) — AHORA SON SECRETOS DEL SERVIDOR ----
# La validación y el canje ocurren en /api/redeem (nadie puede leerlos desde la
# web ni auto-asignarse Pro). Sepáralos por coma o salto de línea. Puedes poner
# una nota tras un '#'. Ejemplo:
ACCESS_CODES=FAMILIA2026, PRUEBA-7H2K9 # nota opcional, AMIGO-TENIS

# (Opcional) Caducidad de TODOS los códigos. Tras esta fecha (fin del día) el
# servidor rechaza cualquier canje. Déjalo vacío para que no caduquen.
ACCESS_CODES_EXPIRES=2026-06-26

# ---- FIREBASE ADMIN (para la función serverless /api/agent) ----
# Pega aquí el JSON COMPLETO de la cuenta de servicio, en UNA sola línea.
# Lo obtienes en: Firebase Console -> Configuración del proyecto ->
# Cuentas de servicio -> "Generar nueva clave privada".
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
